# Run specific variables
dat = HCP2016FreeSurferSubcortical_abcd_baselineYear1Arm1_rest_allsubs.csv
beh_f = abcd_cbcl_grps_model_fits_baseline.csv
pipe = ridgeCV_zscore_group_2Fold_confound_removal_wcategorical


# The environment
universe    = vanilla
getenv      = True

# Resources
request_cpus   = 1
request_memory = 8G
request_disk   = 1G

# Execution
initialdir = /data/project/impulsivity/pfactors/code/juseless/
executable = $(initialdir)/run_in_venv.sh
transfer_executable = False

arguments = HCP_env python prediction_nestedCV_val.py $(dat) $(beh_f) $(beh_i) $(pipe)

# Job
log         = $(initialdir)/logs/ridge_perm/$(beh_f)_$(beh_i)_$(pipe)_$(Cluster).$(Process).log
output      = $(initialdir)/logs/ridge_perm/$(beh_f)_$(beh_i)_$(pipe)_$(Cluster).$(Process).out
error       = $(initialdir)/logs/ridge_perm/$(beh_f)_$(beh_i)_$(pipe)_$(Cluster).$(Process).err

queue beh_i from opts/behs.txt
