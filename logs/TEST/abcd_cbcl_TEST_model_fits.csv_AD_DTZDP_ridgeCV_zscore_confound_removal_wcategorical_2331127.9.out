                                                   '26', '27', '28', '29', ...]),
                                                 ('cat', 'passthrough',
                                                  ['gender'])])),
                ('confoundremover',
                 ConfoundRemover(model_confound=LinearRegression(),
                                 n_confounds=2)),
                ('ridgecv',
                 RidgeCV(alphas=array([1.e+00, 1.e+01, 1.e+02, 1.e+03, 1.e+04, 1.e+05]),
                         scoring='neg_root_mean_squared_error',
                         store_cv_values=True))])
